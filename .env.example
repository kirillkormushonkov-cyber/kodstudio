# ---------- Public site ----------
NEXT_PUBLIC_SITE_URL=https://kodstudio.dev

# ---------- Brief form (existing) ----------
# Telegram or Slack webhook for new project briefs.
# BRIEF_WEBHOOK_URL=

# ---------- Reviews: database (Neon Postgres) ----------
# 1. Vercel → Storage → Marketplace → Neon → Create database
# 2. Copy the pooled connection string (sslmode=require)
# 3. Run db/schema.sql once via Neon SQL Editor
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ---------- Reviews: spam protection (Cloudflare Turnstile) ----------
# Free, get keys at https://dash.cloudflare.com → Turnstile → Add Site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---------- Reviews: admin panel ----------
# Used by /admin/* routes (HTTP Basic Auth via src/proxy.ts).
# Pick a long random password — rotate it like you'd rotate any secret.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-please
